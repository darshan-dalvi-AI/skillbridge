# Backend (Render) environment variables — set these in the Render dashboard,
# do NOT commit real values.

# Postgres from Neon (https://neon.tech). When set, the backend uses Postgres.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Google Gemini (AI roadmap / mentor / JD parsing)
GEMINI_API_KEY=

# Adzuna live job-market data (optional; falls back to curated index if blank)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
