# Backend (Render) environment variables — set these in the Render dashboard,
# do NOT commit real values.

# Postgres from Neon (https://neon.tech). When set, the backend uses Postgres.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# OpenRouter — powers ALL AI: roadmap / mentor / JD parsing / cover letter /
# market pulse AND the semantic skill embeddings. Get a key at https://openrouter.ai
OPENROUTER_API_KEY=
# Optional model overrides (sensible defaults are built in):
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small

# Adzuna live job-market data (optional; falls back to curated index if blank)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
