# Streamlit Community Cloud -> your app -> Settings -> Secrets.
# Paste these (with real values). This file is only a template; the real
# secrets.toml is gitignored and never committed.

SKILLBRIDGE_API_URL = "https://YOUR-RENDER-APP.onrender.com"
GEMINI_API_KEY = "your-gemini-key"
ADZUNA_APP_ID  = "your-adzuna-id"
ADZUNA_APP_KEY = "your-adzuna-key"

# --- Google Sign-in (Streamlit native OIDC) ---
# 1) Google Cloud Console -> Credentials -> Create OAuth client ID -> Web application
# 2) Authorized redirect URI:  https://skillbridge-darshan.streamlit.app/oauth2callback
# 3) Paste client_id / client_secret below; keep cookie_secret long & random.
[auth]
redirect_uri = "https://skillbridge-darshan.streamlit.app/oauth2callback"
cookie_secret = "REPLACE_WITH_LONG_RANDOM_STRING"
client_id = "YOUR_ID.apps.googleusercontent.com"
client_secret = "YOUR_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
